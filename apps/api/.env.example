# ----------------------------------------------------------------------------
# Payday API — environment configuration
# Copy to ".env" and fill in real values. Never commit the populated .env file.
# ----------------------------------------------------------------------------

# Application
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# CORS — comma separated list of allowed origins (the Next.js web app)
BACKEND_CORS_ORIGINS=http://localhost:3000

# Database
# Production example (PostgreSQL via asyncpg):
#   postgresql+asyncpg://payday:payday@localhost:5432/payday
# Local dev default falls back to async SQLite if unset.
DATABASE_URL=postgresql+asyncpg://payday:payday@localhost:5432/payday

# ----------------------------------------------------------------------------
# ALATPay (Wema Bank) integration
# ----------------------------------------------------------------------------
ALATPAY_BASE_URL=https://apibox.alatpay.ng
ALATPAY_API_KEY=replace-me
ALATPAY_BUSINESS_ID=replace-me
# Secret used to verify the signature on inbound ALATPay webhooks.
ALATPAY_WEBHOOK_SECRET=replace-me
# Outbound HTTP timeout (seconds)
ALATPAY_TIMEOUT_SECONDS=30
