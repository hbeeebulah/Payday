# ----------------------------------------------------------------------------
# Payday API — environment configuration
# Copy to ".env" and fill in real values. Never commit the populated .env file.
# ----------------------------------------------------------------------------

# Application
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# CORS — comma separated list of allowed origins (the Next.js web app)
BACKEND_CORS_ORIGINS=http://localhost:3000

# Database
# Production example (PostgreSQL via asyncpg):
#   postgresql+asyncpg://payday:payday@localhost:5432/payday
# Local dev default falls back to async SQLite if unset.
DATABASE_URL=postgresql+asyncpg://payday:payday@localhost:5432/payday

# ----------------------------------------------------------------------------
# Disbursement backend
#   collection -> ALATPay collection rails (default; sandbox/demo)
#   payout     -> real Wema Merchant Payout (NIP disbursement) API
# ----------------------------------------------------------------------------
DISBURSEMENT_MODE=collection

# ----------------------------------------------------------------------------
# ALATPay (collection / Transaction Monitoring)
# ----------------------------------------------------------------------------
ALATPAY_BASE_URL=https://apibox.alatpay.ng
ALATPAY_API_KEY=replace-me
ALATPAY_PUBLIC_KEY=replace-me
ALATPAY_BUSINESS_ID=replace-me
ALATPAY_WEBHOOK_SECRET=
ALATPAY_TIMEOUT_SECONDS=30
ALATPAY_WALLET_TYPE=2
WEMA_BANK_CODE=035
ALATPAY_DISBURSEMENT_CONCURRENCY=10

# ----------------------------------------------------------------------------
# Wema Merchant Payout (real NIP disbursement) — required when DISBURSEMENT_MODE=payout
# All values below (except base URL) are issued by your Wema bank liaison.
# ----------------------------------------------------------------------------
PAYOUT_BASE_URL=https://apps.wemabank.com/WemaAPIService/
PAYOUT_USERNAME=replace-me
PAYOUT_PASSWORD=replace-me
# Vendor id sent as the `VendorId` header.
PAYOUT_VENDOR_ID=replace-me
# Azure APIM subscription key (Ocp-Apim-Subscription-Key); optional/depends on tier.
PAYOUT_SUBSCRIPTION_KEY=
# AES-128 key + IV (16 ASCII chars each). Defaults are the PUBLIC SANDBOX values —
# override with your per-merchant production key/IV.
PAYOUT_ENCRYPTION_KEY=)KCSWITHC%^$$%@H
PAYOUT_ENCRYPTION_IV=#$%#^%KCSWITC945
# Your merchant debit/source account profiled with Wema.
PAYOUT_SOURCE_ACCOUNT=replace-me
# Originator display name shown to beneficiaries.
PAYOUT_ORIGINATOR_NAME=Payday
PAYOUT_TIMEOUT_SECONDS=30
